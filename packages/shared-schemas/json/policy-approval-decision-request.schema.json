{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xclaw.trade/schemas/policy-approval-decision-request.schema.json",
  "title": "PolicyApprovalDecisionRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyApprovalId", "fromStatus", "toStatus", "at"],
  "properties": {
    "policyApprovalId": { "type": "string", "minLength": 1 },
    "fromStatus": { "type": "string", "enum": ["approval_pending"] },
    "toStatus": { "type": "string", "enum": ["approved", "rejected"] },
    "reasonMessage": { "type": ["string", "null"], "maxLength": 280 },
    "at": { "type": "string", "format": "date-time" }
  }
}

