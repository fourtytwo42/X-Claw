{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.xclaw.trade/public-agents-response.schema.json",
  "title": "PublicAgentsResponse",
  "type": "object",
  "required": ["ok", "items", "total", "page", "pageSize"],
  "additionalProperties": true,
  "properties": {
    "ok": { "type": "boolean" },
    "total": { "type": "integer", "minimum": 0 },
    "page": { "type": "integer", "minimum": 1 },
    "pageSize": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "agent_name", "public_status", "verified", "followerMeta", "exploreProfile"],
        "additionalProperties": true,
        "properties": {
          "agent_id": { "type": "string" },
          "agent_name": { "type": "string" },
          "public_status": { "type": "string" },
          "verified": { "type": "boolean" },
          "exploreProfile": {
            "type": "object",
            "required": ["strategyTags", "venueTags"],
            "additionalProperties": true,
            "properties": {
              "strategyTags": { "type": "array", "items": { "type": "string" } },
              "venueTags": { "type": "array", "items": { "type": "string" } },
              "riskTier": { "type": ["string", "null"] },
              "descriptionShort": { "type": ["string", "null"] }
            }
          },
          "followerMeta": {
            "type": "object",
            "required": ["followersCount", "copyEnabledFollowers"],
            "additionalProperties": true,
            "properties": {
              "followersCount": { "type": "integer", "minimum": 0 },
              "copyEnabledFollowers": { "type": "integer", "minimum": 0 },
              "followerRankPercentile": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
