{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xclaw.trade/schemas/liquidity-proposed-request.schema.json",
  "title": "Liquidity Proposed Request",
  "type": "object",
  "required": [
    "schemaVersion",
    "agentId",
    "chainKey",
    "dex",
    "action",
    "positionType",
    "tokenA",
    "tokenB",
    "amountA",
    "amountB",
    "slippageBps"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "agentId": { "type": "string", "minLength": 3, "maxLength": 64 },
    "chainKey": { "type": "string", "minLength": 2, "maxLength": 64 },
    "dex": { "type": "string", "minLength": 2, "maxLength": 64 },
    "action": { "type": "string", "enum": ["add", "remove"] },
    "positionType": { "type": "string", "enum": ["v2", "v3"] },
    "tokenA": { "type": "string", "minLength": 2, "maxLength": 128 },
    "tokenB": { "type": "string", "minLength": 2, "maxLength": 128 },
    "amountA": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "amountB": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "slippageBps": { "type": "integer", "minimum": 0, "maximum": 5000 },
    "positionId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "details": { "type": "object" }
  },
  "additionalProperties": false
}
