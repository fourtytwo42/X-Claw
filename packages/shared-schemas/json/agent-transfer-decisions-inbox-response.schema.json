{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.xclaw.trade/agent-transfer-decisions-inbox-response.schema.json",
  "title": "AgentTransferDecisionsInboxResponse",
  "type": "object",
  "required": ["ok", "agentId", "count", "decisions"],
  "additionalProperties": false,
  "properties": {
    "ok": { "type": "boolean", "const": true },
    "agentId": { "type": "string", "minLength": 1 },
    "chainKey": { "type": ["string", "null"], "minLength": 1 },
    "count": { "type": "integer", "minimum": 0 },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decisionId", "approvalId", "chainKey", "decision", "source", "createdAt"],
        "additionalProperties": false,
        "properties": {
          "decisionId": { "type": "string", "minLength": 1 },
          "approvalId": { "type": "string", "minLength": 1 },
          "chainKey": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "enum": ["approve", "deny"] },
          "reasonMessage": { "type": ["string", "null"] },
          "decisionPayload": {
            "type": ["object", "null"],
            "additionalProperties": true,
            "properties": {
              "kind": { "type": "string", "enum": ["management_withdraw_v1"] },
              "chainKey": { "type": "string", "minLength": 1 },
              "transferType": { "type": "string", "enum": ["native", "token"] },
              "toAddress": {
                "type": "string",
                "anyOf": [
                  { "pattern": "^0x[a-fA-F0-9]{40}$" },
                  { "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,64}$" }
                ]
              },
              "amountWei": { "type": "string", "pattern": "^[0-9]+$" },
              "tokenAddress": {
                "type": ["string", "null"],
                "anyOf": [
                  { "type": "null" },
                  { "pattern": "^0x[a-fA-F0-9]{40}$" },
                  { "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,64}$" }
                ]
              },
              "tokenSymbol": { "type": ["string", "null"] },
              "tokenDecimals": { "type": ["integer", "null"], "minimum": 0, "maximum": 255 }
            }
          },
          "source": { "type": "string", "minLength": 1 },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
