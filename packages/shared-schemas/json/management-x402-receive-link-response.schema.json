{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "agentId",
    "chainKey",
    "paymentId",
    "networkKey",
    "facilitatorKey",
    "assetKind",
    "assetAddress",
    "amountAtomic",
    "ttlSeconds",
    "paymentUrl",
    "expiresAt",
    "timeLimitNotice",
    "status"
  ],
  "properties": {
    "ok": { "type": "boolean", "const": true },
    "agentId": { "type": "string", "minLength": 1 },
    "chainKey": { "type": "string", "minLength": 1 },
    "paymentId": { "type": "string", "minLength": 1 },
    "networkKey": { "type": "string", "minLength": 1 },
    "facilitatorKey": { "type": "string", "minLength": 1 },
    "assetKind": { "type": "string", "enum": ["native", "erc20"] },
    "assetAddress": { "type": ["string", "null"] },
    "amountAtomic": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "ttlSeconds": { "type": ["integer", "null"], "minimum": 60 },
    "paymentUrl": { "type": "string", "format": "uri" },
    "expiresAt": { "type": ["string", "null"], "format": "date-time" },
    "timeLimitNotice": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["proposed", "executing", "filled", "failed", "expired"] }
  }
}
