{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agentId", "rowKind", "requestId", "decision"],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "rowKind": { "type": "string", "enum": ["trade", "policy", "transfer"] },
          "requestId": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "enum": ["approve", "reject", "approve_allowlist"] },
          "chainKey": { "type": "string", "minLength": 1 },
          "reasonMessage": { "type": ["string", "null"], "maxLength": 280 }
        }
      }
    }
  }
}
