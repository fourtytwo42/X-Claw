{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.xclaw.trade/management-default-chain-batch-update-response.schema.json",
  "type": "object",
  "required": ["ok", "chainKey", "total", "successCount", "failureCount", "results"],
  "properties": {
    "ok": { "type": "boolean", "const": true },
    "chainKey": { "type": "string", "minLength": 1 },
    "total": { "type": "integer", "minimum": 0 },
    "successCount": { "type": "integer", "minimum": 0 },
    "failureCount": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId", "ok", "status"],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "ok": { "type": "boolean" },
          "status": { "type": "integer" },
          "response": { "type": ["object", "null"] }
        }
      }
    }
  }
}
