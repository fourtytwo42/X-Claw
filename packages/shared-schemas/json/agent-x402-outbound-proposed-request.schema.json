{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "paymentId",
    "approvalId",
    "networkKey",
    "facilitatorKey",
    "status",
    "assetKind",
    "amountAtomic",
    "url",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "paymentId": { "type": "string", "minLength": 1 },
    "approvalId": { "type": "string", "minLength": 1 },
    "networkKey": { "type": "string", "minLength": 1 },
    "facilitatorKey": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["proposed", "approval_pending", "approved", "executing", "filled", "failed", "rejected"]
    },
    "assetKind": { "type": "string", "enum": ["native", "token", "erc20"] },
    "assetAddress": {
      "type": ["string", "null"],
      "anyOf": [
        { "type": "null" },
        { "pattern": "^0x[a-fA-F0-9]{40}$" },
        { "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,64}$" }
      ]
    },
    "assetSymbol": { "type": ["string", "null"] },
    "amountAtomic": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "url": { "type": "string", "format": "uri" },
    "txHash": {
      "type": ["string", "null"],
      "anyOf": [
        { "type": "null" },
        { "pattern": "^0x[a-fA-F0-9]{64}$" },
        { "pattern": "^[1-9A-HJ-NP-Za-km-z]{64,128}$" }
      ]
    },
    "reasonCode": { "type": ["string", "null"] },
    "reasonMessage": { "type": ["string", "null"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "terminalAt": { "type": ["string", "null"], "format": "date-time" }
  }
}
