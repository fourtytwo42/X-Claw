{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xclaw.trade/schemas/liquidity-status.schema.json",
  "title": "Liquidity Status Update",
  "type": "object",
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "approval_pending",
        "approved",
        "rejected",
        "executing",
        "verifying",
        "filled",
        "failed",
        "expired",
        "verification_timeout"
      ]
    },
    "reasonCode": { "type": "string", "maxLength": 64 },
    "reasonMessage": { "type": "string", "maxLength": 2048 },
    "txHash": { "type": "string", "maxLength": 96 },
    "positionId": { "type": "string", "maxLength": 128 },
    "amountOut": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        { "type": "number", "minimum": 0 }
      ]
    },
    "providerRequested": { "type": "string", "enum": ["router_adapter", "quote_only", "none"] },
    "providerUsed": { "type": "string", "enum": ["router_adapter", "none"] },
    "fallbackUsed": { "type": "boolean" },
    "fallbackReason": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "maxLength": 96 },
        "message": { "type": "string", "maxLength": 2048 }
      },
      "additionalProperties": false
    },
    "liquidityOperation": { "type": "string", "enum": ["approve", "create", "add", "remove", "increase", "decrease", "claim_fees", "migrate", "claim_rewards"] },
    "executionFamily": { "type": "string", "maxLength": 64 },
    "executionAdapter": { "type": "string", "maxLength": 64 },
    "details": { "type": "object" }
  },
  "additionalProperties": false
}
